{
  "name": "difftest",
  "version": "0.1.0",
  "description": "Run only the tests your diff can actually break. Coverage-based test selection that catches what static import graphs miss — for Jest, Vitest & monorepos.",
  "type": "module",
  "bin": {
    "difftest": "bin/difftest.js"
  },
  "files": [
    "bin",
    "src",
    "README.md"
  ],
  "scripts": {
    "difftest": "node bin/difftest.js",
    "test": "node --test"
  },
  "keywords": [
    "test",
    "test-selection",
    "regression-test-selection",
    "jest",
    "vitest",
    "ci",
    "coverage",
    "monorepo",
    "git",
    "diff"
  ],
  "engines": {
    "node": ">=18"
  },
  "author": "Kazutaka Sugiyama",
  "license": "MIT",
  "homepage": "https://github.com/TwistTheoryGames/difftest#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TwistTheoryGames/difftest.git"
  },
  "bugs": {
    "url": "https://github.com/TwistTheoryGames/difftest/issues"
  }
}
